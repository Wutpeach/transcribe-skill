# =============================================
# Step 1: FunASR
# base URL is fixed in config/funasr.toml
# only the API key is required
# =============================================
FUNASR_API_KEY=your_funasr_key_here

# =============================================
# Step 2A: auxiliary model
# OpenAI-compatible endpoint
# provide both base URL and API key
# =============================================
AUXILIARY_BASE_URL=https://api.deepseek.com/v1
AUXILIARY_API_KEY=your_auxiliary_key_here

# Optional legacy host fallback:
# some hosts may also provide these secrets through managed local config.
